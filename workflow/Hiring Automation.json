    {
      "parameters": {
        "jsCode": "const SUPABASE_URL = \"\";\nconst SUPABASE_KEY = \"\";\n\n// Step 1: Fetch from Supabase (email + role_type)\nconst dbResponse = await this.helpers.httpRequest({\n  method: \"GET\",\n  url: `${SUPABASE_URL}/rest/v1/candidates?select=email,role_type`,\n  headers: {\n    apikey: SUPABASE_KEY,\n    Authorization: `Bearer ${SUPABASE_KEY}`\n  }\n});\n\n// Step 2: Create Set — Supabase has \"email\" and \"role_type\"\nconst dbKeys = new Set(\n  dbResponse.map(row =>\n    `${row.email?.toLowerCase().trim()}|${row.role_type?.toLowerCase().trim()}`\n  )\n);\n\n// Step 3: Get merge node input\nconst formData = $input.all().map(item => item.json);\n\n// Step 4: Filter — input has \"Email_Address\" and \"Role_Type\"\nconst newEntries = formData.filter(entry => {\n  const email = (entry.Email_Address || \"\").toLowerCase().trim();\n  const role  = (entry.Role_Type     || \"\").toLowerCase().trim();\n  const key   = `${email}|${role}`;\n  return key !== \"|\" && !dbKeys.has(key);\n});\n\n// Step 5: Return\nreturn newEntries.map(entry => ({ json: entry }));"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
